        <mxCell id="expense" value="Expense&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#AAAAAA&quot;&gt;Supplies, etc.&lt;/font&gt;" style="rounded=1;html=1;fillColor=#0a0a0a;strokeColor=#F97316;fontColor=#F97316;fontSize=10;arcSize=15;whiteSpace=wrap;" vertex="1" parent="1">
