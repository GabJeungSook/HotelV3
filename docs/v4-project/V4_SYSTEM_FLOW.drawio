        </mxCell>

        <mxCell id="shift_close" value="End Shift&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#AAAAAA&quot;&gt;1. Count closing cash&lt;br&gt;2. Expected = open + payments&lt;br&gt;   - refunds - remit - expenses&lt;br&gt;3. Difference = actual - expected&lt;/font&gt;" style="rounded=1;html=1;fillColor=#0a0a0a;strokeColor=#EF4444;fontColor=#FFFFFF;fontSize=10;arcSize=15;whiteSpace=wrap;align=left;spacingLeft=8;" vertex="1" parent="1">
