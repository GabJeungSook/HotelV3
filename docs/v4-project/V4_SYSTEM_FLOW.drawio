        </mxCell>

        <!-- Shift close -->
        <mxCell id="shift_close" value="End Shift&#xa;1. Count closing cash&#xa;2. Expected = opening + payments&#xa;   + deposits - refunds&#xa;   - remittances - expenses&#xa;3. Difference = actual - expected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2a1a1a;strokeColor=#EF4444;fontColor=#FFFFFF;fontSize=11;arcSize=15;align=left;spacingLeft=10;" vertex="1" parent="1">
